# ── Banco de dados (Supabase) ─────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:SENHA@db.PROJETO.supabase.co:5432/postgres?schema=public"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT é injetado automaticamente pelo Railway

# ── CORS — aceita múltiplas origens separadas por vírgula ─────────────────────
CORS_ORIGIN="https://gestao-lojas.vercel.app,https://gestao-lojas-git-main-davidsantos96.vercel.app,http://localhost:5173"

# ── Upload de arquivos ────────────────────────────────────────────────────────
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
