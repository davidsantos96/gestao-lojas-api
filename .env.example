# Copie para .env e ajuste

# PostgreSQL
DATABASE_URL="postgresql://postgres:senha@localhost:5432/sistema_lojas?schema=public"

# App
PORT=3000
NODE_ENV=development

# CORS — origem do frontend
CORS_ORIGIN="http://localhost:5173"

# Upload de arquivos (local ou S3)
STORAGE_DRIVER=local          # local | s3
UPLOAD_DIR=./uploads          # usado quando STORAGE_DRIVER=local
# AWS_BUCKET=meu-bucket
# AWS_REGION=sa-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
